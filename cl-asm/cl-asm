#!/usr/bin/env bash
# cl-asm -- Assembleur en ligne de commande pour cl-asm
#
# Usage :
#   ./cl-asm source.asm               -> source.prg (6502, origine $0801)
#   ./cl-asm source.lasm              -> source.prg (6502, origine $0801)
#   ./cl-asm source.asm -o out.prg
#   ./cl-asm source.asm -o out.bin --format bin
#   ./cl-asm source.asm --origin 0xC000
#   ./cl-asm source.asm --target 45gs02 --origin 0x2001
#   ./cl-asm --help
#
# Detection automatique de la cible :
#   .asm  : ligne commencant par "; target: 45gs02"
#   .lasm : ligne contenant "(target :45gs02)"
#   --target sur la ligne de commande est toujours prioritaire.

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# --------------------------------------------------------------------------
#  Valeurs par defaut
# --------------------------------------------------------------------------

INPUT=""
OUTPUT=""
FORMAT="prg"
ORIGIN_HEX=""
TARGET="6502"
TARGET_EXPLICIT=0
VERBOSE=0

# --------------------------------------------------------------------------
#  Aide
# --------------------------------------------------------------------------

usage() {
  cat << 'EOF'
cl-asm — assembleur multi-architecture en Common Lisp

USAGE
  cl-asm [OPTIONS] fichier.asm
  cl-asm [OPTIONS] fichier.lasm

DETECTION AUTOMATIQUE DE LA CIBLE
  Ajouter en tete du fichier source :
    .asm  : ; target: 45gs02   ou   ; target: x16
    .lasm : (target :45gs02)
  L'option --target est prioritaire sur la detection automatique.

OPTIONS
  -o, --output FILE     fichier de sortie (defaut : meme nom, ext .prg/.bin)
  -f, --format FORMAT   format de sortie : prg (defaut) ou bin
      --origin ADDR     adresse d'origine hex (ex: 0x0801 ou $0801)
                        defaut : 0x0801 pour 6502/x16, 0x2001 pour 45gs02
  -t, --target TARGET   architecture : 6502 (defaut), 45gs02 ou x16
  -v, --verbose         affiche les details de l'assemblage
  -h, --help            affiche cette aide

EXEMPLES
  cl-asm programme.asm
  cl-asm programme.asm -o demo.prg
  cl-asm programme.asm -o demo.bin --format bin
  cl-asm programme.asm --origin 0xC000
  cl-asm mega65.lasm --target 45gs02
  cl-asm mega65.lasm              # si (target :45gs02) est dans le fichier

FORMATS DE SORTIE
  prg   2 octets header LE + binaire (LOAD "FILE",8,1 sur C64/Mega65)
  bin   Binaire brut sans header
EOF
}

# --------------------------------------------------------------------------
#  Parsing des arguments
# --------------------------------------------------------------------------

while [[ $# -gt 0 ]]; do
  case "$1" in
    -h|--help)
      usage; exit 0 ;;
    -o|--output)
      OUTPUT="$2"; shift 2 ;;
    -f|--format)
      FORMAT="$2"; shift 2 ;;
    --origin)
      ORIGIN_HEX="$2"; shift 2 ;;
    -t|--target)
      TARGET="$2"; TARGET_EXPLICIT=1; shift 2 ;;
    -v|--verbose)
      VERBOSE=1; shift ;;
    -*)
      echo "Option inconnue : $1" >&2
      echo "Utilisez --help pour l'aide." >&2
      exit 1 ;;
    *)
      if [[ -z "$INPUT" ]]; then
        INPUT="$1"
      else
        echo "Argument inattendu : $1" >&2; exit 1
      fi
      shift ;;
  esac
done

# --------------------------------------------------------------------------
#  Verifications
# --------------------------------------------------------------------------

if [[ -z "$INPUT" ]]; then
  echo "Erreur : fichier source manquant." >&2
  echo "Utilisez --help pour l'aide." >&2
  exit 1
fi

if [[ ! -f "$INPUT" ]]; then
  echo "Erreur : fichier introuvable : $INPUT" >&2
  exit 1
fi

if [[ "$FORMAT" != "prg" && "$FORMAT" != "bin" ]]; then
  echo "Erreur : format invalide '$FORMAT'. Utiliser 'prg' ou 'bin'." >&2
  exit 1
fi

if [[ "$TARGET" != "6502" && "$TARGET" != "45gs02" && "$TARGET" != "x16" ]]; then
  echo "Erreur : cible invalide '$TARGET'. Utiliser '6502', '45gs02' ou 'x16'." >&2
  exit 1
fi

# --------------------------------------------------------------------------
#  Detection du frontend
# --------------------------------------------------------------------------

EXT="${INPUT##*.}"
if [[ "$EXT" == "lasm" ]]; then
  FRONTEND="lasm"
else
  FRONTEND="classic"
fi

# --------------------------------------------------------------------------
#  Detection automatique de la cible
# --------------------------------------------------------------------------

if [[ "$TARGET_EXPLICIT" -eq 0 ]]; then
  if [[ "$FRONTEND" == "lasm" ]]; then
    if head -40 "$INPUT" | grep -qi '(target :45gs02)'; then
      TARGET="45gs02"
      [[ $VERBOSE -eq 1 ]] && echo "Cible detectee dans le source : 45gs02"
    fi
  else
    if head -10 "$INPUT" | grep -qi '^\s*;\s*target:\s*45gs02'; then
      TARGET="45gs02"
    elif head -10 "$INPUT" | grep -qi '^\s*;\s*target:\s*x16'; then
      TARGET="x16"
      [[ $VERBOSE -eq 1 ]] && echo "Cible detectee dans le source : 45gs02"
    fi
  fi
fi

# --------------------------------------------------------------------------
#  Adresse d'origine
#  Conversion en entier decimal pour eviter les problemes Lisp avec 0x...
# --------------------------------------------------------------------------

if [[ -z "$ORIGIN_HEX" ]]; then
  if [[ "$TARGET" == "45gs02" ]]; then
    ORIGIN_HEX="0x2001"
  else
    ORIGIN_HEX="0x0801"
  fi
fi

# Normaliser $0801 -> 0x0801 puis convertir en decimal
ORIGIN_HEX="${ORIGIN_HEX/\$/0x}"
ORIGIN_DEC=$(python3 -c "print(int('$ORIGIN_HEX', 16))" 2>/dev/null \
             || printf '%d' "$ORIGIN_HEX" 2>/dev/null \
             || echo "2049")

# --------------------------------------------------------------------------
if [[ "$FRONTEND" == "lasm" ]]; then
  LISP_FRONTEND="t"   # truthy = lasm
else
  LISP_FRONTEND="nil" # nil = classic
fi

if [[ "$FORMAT" == "prg" ]]; then
  LISP_FORMAT="t"    # truthy = prg
else
  LISP_FORMAT="nil"  # nil = bin
fi

# --------------------------------------------------------------------------
#  Fichier de sortie
# --------------------------------------------------------------------------

if [[ -z "$OUTPUT" ]]; then
  BASE="${INPUT%.*}"
  OUTPUT="${BASE}.${FORMAT}"
fi

# --------------------------------------------------------------------------
#  Verbose
# --------------------------------------------------------------------------

if [[ $VERBOSE -eq 1 ]]; then
  echo "Source   : $(realpath "$INPUT")"
  echo "Sortie   : $(realpath -m "$OUTPUT")"
  echo "Format   : $FORMAT"
  echo "Origine  : $ORIGIN_HEX ($ORIGIN_DEC)"
  echo "Cible    : $TARGET"
  echo "Frontend : $FRONTEND"
  echo ""
fi

# --------------------------------------------------------------------------
#  Assemblage via SBCL — le code Lisp est ecrit dans un fichier temporaire
#  pour eviter tous les problemes de quoting shell dans --eval.
# --------------------------------------------------------------------------

INPUT_ABS="$(realpath "$INPUT")"
OUTPUT_ABS="$(realpath -m "$OUTPUT")"

# Fichier temporaire pour le script Lisp
LISP_TMP="$(mktemp /tmp/cl-asm-XXXXXX.lisp)"
trap "rm -f $LISP_TMP" EXIT

# Ecrire le script Lisp dans le fichier temporaire
cat > "$LISP_TMP" << ENDLISP
(handler-case
  (let* ((origin   $ORIGIN_DEC)
         (target   :$TARGET)
         (use-lasm $LISP_FRONTEND)
         (use-prg  $LISP_FORMAT)
         (source   "$INPUT_ABS")
         (output   "$OUTPUT_ABS")
         (program
           (if use-lasm
               (cl-asm/lasm:load-lasm source)
               (cl-asm/parser:parse-file source)))
         (bytes
           (ecase target
             (:45gs02
              (cl-asm/backend.45gs02:assemble-45gs02 program :origin origin))
             (:x16
              (cl-asm/backend.65c02:assemble-65c02 program :origin origin))
             (:6502
              (cl-asm/backend.6502:assemble program :origin origin)))))
    (if use-prg
        (cl-asm/emit:write-prg bytes output :load-address origin)
        (cl-asm/emit:write-bin bytes output))
    (format t "~A -> ~A (~D octets)~%"
            (file-namestring source)
            (file-namestring output)
            (length bytes)))
  (cl-asm/ir:asm-error (e)
    (format *error-output* "Erreur d'assemblage : ~A~%" e)
    (sb-ext:exit :code 1))
  (error (e)
    (format *error-output* "Erreur : ~A~%" e)
    (sb-ext:exit :code 1)))
ENDLISP

sbcl --noinform \
     --load "$SCRIPT_DIR/src/core/version.lisp" \
     --load "$SCRIPT_DIR/src/core/ir.lisp" \
     --load "$SCRIPT_DIR/src/core/expression.lisp" \
     --load "$SCRIPT_DIR/src/core/symbol-table.lisp" \
     --load "$SCRIPT_DIR/src/frontend/classic-lexer.lisp" \
     --load "$SCRIPT_DIR/src/frontend/classic-parser.lisp" \
     --load "$SCRIPT_DIR/src/backend/6502.lisp" \
     --load "$SCRIPT_DIR/src/backend/45gs02.lisp" \
     --load "$SCRIPT_DIR/src/backend/65c02.lisp" \
     --load "$SCRIPT_DIR/src/emit/output.lisp" \
     --load "$SCRIPT_DIR/src/frontend/lasm.lisp" \
     --load "$LISP_TMP" \
     --quit
