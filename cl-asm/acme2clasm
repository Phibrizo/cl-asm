#!/usr/bin/env python3
# -*- coding: utf-8 -*-
"""
acme2clasm -- Convertit un fichier source ACME vers la syntaxe cl-asm.

Usage :
  ./acme2clasm source.s                -> source.asm (meme repertoire)
  ./acme2clasm source.s -o sortie.asm
  ./acme2clasm source.s --report       -> affiche le rapport de conversion

Conversions automatiques :
  !cpu ...            -> commentaire (information seulement)
  !to "file", fmt     -> commentaire (information pour l'assemblage)
  !addr NOM = VALEUR  -> NOM = VALEUR
  !byte / !8          -> .byte
  !word / !16         -> .word
  !32                 -> .dword
  !text               -> .text
  !pet "..."          -> .byte (octets PETSCII explicites)
  !fill N, VAL        -> .fill N, VAL
  !align N            -> .align N
  !source "fichier"   -> commentaire + avertissement
  !binary "fichier"   -> commentaire + avertissement
  !macro NOM { }      -> .macro NOM / .endmacro  (avertissement si complexe)
  !if EXPR { }        -> .if EXPR / .endif
  * = ADDR            -> .org ADDR
  Label sans ':'      -> Label:
  AND / OR / EOR      -> & / | / ^  dans les expressions
"""

import re
import sys
import os
import argparse
import unicodedata


def to_ascii_comment(text):
    """Convertit les caracteres non-ASCII en ASCII dans un commentaire."""
    result = []
    for ch in text:
        if ord(ch) < 128:
            result.append(ch)
        else:
            normalized = unicodedata.normalize('NFD', ch)
            ascii_part = ''.join(c for c in normalized if ord(c) < 128)
            result.append(ascii_part if ascii_part else '?')
    return ''.join(result)


# --------------------------------------------------------------------------
#  Conversion PETSCII -> codes ecran
# --------------------------------------------------------------------------

def pet_string_to_bytes(s):
    """
    Convertit une chaine PETSCII litterale (contenu entre guillemets dans
    !pet "...") en liste d'octets decimaux.
    PETSCII majuscules : A-Z = $41-$5A
    Chiffres : 0-9 = $30-$39
    """
    result = []
    i = 0
    while i < len(s):
        ch = s[i]
        if ch == '\\' and i + 1 < len(s):
            nxt = s[i+1]
            if nxt == 'n':   result.append(0x0D); i += 2; continue
            if nxt == 't':   result.append(0x09); i += 2; continue
            if nxt == '\\':  result.append(ord('\\')); i += 2; continue
            if nxt == '"':   result.append(ord('"')); i += 2; continue
            if nxt == 'x' and i + 3 < len(s):
                result.append(int(s[i+2:i+4], 16)); i += 4; continue
        result.append(ord(ch))
        i += 1
    return result


# --------------------------------------------------------------------------
#  Mnemoniques 6502/45GS02 connus (pour distinguer labels et instructions)
# --------------------------------------------------------------------------

MNEMONICS = {
    'LDA','LDX','LDY','STA','STX','STY','LDZ','STZ',
    'ADC','SBC','CMP','CPX','CPY',
    'AND','ORA','EOR','BIT',
    'INC','DEC','INX','INY','INZ','DEX','DEY','DEZ',
    'ASL','LSR','ROL','ROR',
    'JMP','JSR','RTS','RTI','BRK',
    'BCC','BCS','BEQ','BNE','BMI','BPL','BVC','BVS',
    'LBCC','LBCS','LBEQ','LBNE','LBMI','LBPL','LBVC','LBVS',
    'CLC','SEC','CLI','SEI','CLD','SED','CLV',
    'TAX','TAY','TXA','TYA','TSX','TXS','TAZ','TZA','TAB','TBA',
    'PHA','PLA','PHP','PLP','PHZ','PLZ',
    'NOP','MAP','EOM','NEG','ASR',
    'INW','DEW','ASW','ROW',
    'LDQ','STQ','ADCQ','SBCQ','ANDQ','ORAQ','EORQ',
    'ASLQ','LSRQ','ROLQ','RORQ','ASRQ','BITQ','CMPQ',
}


# --------------------------------------------------------------------------
#  Convertisseur principal
# --------------------------------------------------------------------------

class AcmeConverter:

    def __init__(self, source_path):
        self.source_path = source_path
        self.warnings = []       # (ligne, message)
        self.out_lines = []
        self.in_macro = False
        self.macro_depth = 0

    def warn(self, lineno, msg):
        self.warnings.append((lineno, msg))

    def convert_expression(self, expr):
        """Convertit les operateurs ACME vers cl-asm dans une expression.
        Ne touche pas aux mnemoniques EOR/AND/ORA en debut d'instruction."""
        # AND, OR, EOR en majuscules -> &, |, ^ SEULEMENT dans les expressions
        # (pas quand ils sont en debut de ligne = mnemonique 6502)
        # On les convertit uniquement s'ils sont entoures d'operandes
        expr = re.sub(r'(?<=\S)\s+AND\s+(?=\S)', ' & ', expr)
        expr = re.sub(r'(?<=\S)\s+OR\s+(?=\S)',  ' | ', expr)
        expr = re.sub(r'(?<=\S)\s+EOR\s+(?=\S)', ' ^ ', expr)
        expr = re.sub(r'(?<=\S)\s+XOR\s+(?=\S)', ' ^ ', expr)
        return expr

    def convert_line(self, lineno, line):
        """Convertit une ligne ACME. Retourne la ligne convertie."""

        # Normaliser les fins de ligne et tabs
        line = line.rstrip()

        # Ligne vide
        if not line.strip():
            return ''

        # ---- Extraire indent, code, commentaire ----
        # On separe le commentaire de fin de ligne
        indent = ''
        m = re.match(r'^(\s*)', line)
        if m:
            indent = m.group(1)

        # Commentaire pur (toute la ligne)
        stripped = line.strip()
        if stripped.startswith(';'):
            return line

        # ------------------------------------------------------------------
        #  Directives ACME
        # ------------------------------------------------------------------

        # !cpu -> directive de cible
        m = re.match(r'^\s*!cpu\s+(\S+)', line, re.I)
        if m:
            cpu = m.group(1).lower()
            # m65 / 45gs02 -> cible 45gs02
            if cpu in ('m65', '45gs02'):
                return f'{indent}; target: 45gs02  ; [acme2clasm] !cpu {cpu}'
            # 6502 / 6510 -> cible 6502 (defaut)
            elif cpu in ('6502', '6510', 'nmos6502', '65c02'):
                return f'{indent}; [acme2clasm] !cpu {cpu} -> cible 6502 (defaut)'
            else:
                self.warn(lineno, f'!cpu {cpu} : cible inconnue, verifier manuellement')
                return f'{indent}; TODO [acme2clasm] !cpu {cpu} : cible inconnue'

        # !to "fichier", format -> commentaire
        m = re.match(r'^\s*!to\s+"([^"]+)"\s*,\s*(\w+)', line, re.I)
        if m:
            fname, fmt = m.group(1), m.group(2)
            return (f'{indent}; [acme2clasm] sortie : {fname} (format {fmt})\n'
                    f'{indent}; Assembler avec : ./cl-asm SOURCE -o {fname}')

        # !addr NOM = VALEUR -> NOM = VALEUR
        m = re.match(r'^\s*!addr\s+(\w+)\s*=\s*(.+)', line, re.I)
        if m:
            name, val = m.group(1), m.group(2).strip()
            # Supprimer commentaire eventuel
            val = re.sub(r'\s*;.*$', '', val).strip()
            return f'{indent}{name} = {self.convert_expression(val)}'

        # !byte / !8 -> .byte
        m = re.match(r'^\s*(!byte|!8)\s+(.*)', line, re.I)
        if m:
            args = self.convert_expression(m.group(2))
            return f'{indent}.byte {args}'

        # !word / !16 -> .word
        m = re.match(r'^\s*(!word|!16)\s+(.*)', line, re.I)
        if m:
            args = self.convert_expression(m.group(2))
            return f'{indent}.word {args}'

        # !32 -> .dword
        m = re.match(r'^\s*!32\s+(.*)', line, re.I)
        if m:
            args = self.convert_expression(m.group(2))
            return f'{indent}.dword {args}'

        # !text -> .text
        m = re.match(r'^\s*!text\s+(.*)', line, re.I)
        if m:
            args = m.group(2)
            return f'{indent}.text {args}'

        # !pet "..." -> .byte avec les codes PETSCII
        m = re.match(r'^\s*!pet\s+"([^"]*)"', line, re.I)
        if m:
            content = m.group(1)
            try:
                codes = pet_string_to_bytes(content)
                hex_codes = ', '.join(f'${b:02X}' for b in codes)
                return (f'{indent}.byte {hex_codes}'
                        f'  ; [acme2clasm] !pet "{content}"')
            except Exception:
                self.warn(lineno, f'!pet : conversion impossible de "{content}"')
                return f'{indent}; TODO !pet "{content}"'

        # !fill N, VAL -> .fill N, VAL
        m = re.match(r'^\s*!fill\s+(.*)', line, re.I)
        if m:
            args = self.convert_expression(m.group(1))
            return f'{indent}.fill {args}'

        # !align N -> .align N
        m = re.match(r'^\s*!align\s+(.*)', line, re.I)
        if m:
            args = self.convert_expression(m.group(1))
            return f'{indent}.align {args}'

        # !source "fichier" -> avertissement
        m = re.match(r'^\s*!source\s+"([^"]+)"', line, re.I)
        if m:
            fname = m.group(1)
            self.warn(lineno, f'!source "{fname}" : inclusion manuelle requise')
            return (f'{indent}; TODO [acme2clasm] inclure manuellement : {fname}')

        # !binary "fichier" -> avertissement
        m = re.match(r'^\s*!binary\s+"([^"]+)"', line, re.I)
        if m:
            fname = m.group(1)
            self.warn(lineno, f'!binary "{fname}" : inclusion manuelle requise')
            return (f'{indent}; TODO [acme2clasm] inclure manuellement (binaire) : {fname}')

        # !macro NOM { -> .macro NOM
        m = re.match(r'^\s*!macro\s+(\w+)(\s+[^{]*)?\s*\{?\s*$', line, re.I)
        if m:
            name = m.group(1)
            params = (m.group(2) or '').strip()
            self.in_macro = True
            self.macro_depth = 1
            if params:
                return f'{indent}.macro {name} {params}'
            else:
                return f'{indent}.macro {name}'

        # } fermant une macro
        if self.in_macro and re.match(r'^\s*\}\s*$', line):
            self.in_macro = False
            self.macro_depth = 0
            return f'{indent}.endmacro'

        # !if EXPR { -> .if EXPR
        m = re.match(r'^\s*!if\s+(.+?)\s*\{?\s*$', line, re.I)
        if m:
            expr = self.convert_expression(m.group(1).strip())
            return f'{indent}.if {expr}'

        # } seul apres !if -> .endif
        # (deja traite par la macro ci-dessus si pas in_macro)

        # !else -> .else
        if re.match(r'^\s*!else\b', line, re.I):
            return f'{indent}.else'

        # Directive !zone -> avertissement
        if re.match(r'^\s*!zone\b', line, re.I):
            self.warn(lineno, '!zone : pas d\'equivalent direct, ignore')
            return f'{indent}; [acme2clasm] !zone ignore'

        # !pseudopc -> avertissement
        if re.match(r'^\s*!pseudopc\b', line, re.I):
            self.warn(lineno, '!pseudopc : pas d\'equivalent direct')
            return f'{indent}; TODO [acme2clasm] !pseudopc : conversion manuelle'

        # Directive !inconnue -> commentaire + avertissement
        m = re.match(r'^\s*(![\w]+)\b', line)
        if m:
            directive = m.group(1)
            self.warn(lineno, f'{directive} : directive inconnue, ignoree')
            return f'{indent}; TODO [acme2clasm] {line.strip()}'

        # * = ADDR -> .org ADDR
        m = re.match(r'^\s*\*\s*=\s*(.+)', line)
        if m:
            addr = self.convert_expression(m.group(1).strip())
            addr = re.sub(r'\s*;.*$', '', addr).strip()
            return f'{indent}.org {addr}'

        # ------------------------------------------------------------------
        #  Instructions et labels
        # ------------------------------------------------------------------

        # Detecter les labels sans ':' (style ACME)
        # Un label est un identifiant en debut de ligne (pas d'indent)
        # suivi d'une instruction ou d'une fin de ligne
        if line and not line[0].isspace():
            m = re.match(r'^([A-Za-z_][A-Za-z0-9_]*)\s*(.*)', line)
            if m:
                label_candidate = m.group(1)
                rest = m.group(2).strip()
                # C'est un label si ce n'est pas un mnemonique connu
                # et si le reste ressemble a une instruction ou est vide
                if label_candidate.upper() not in MNEMONICS:
                    # Verifier que le reste n'est pas une assignation
                    if rest and rest[0] == '=':
                        # Assignation : NOM = EXPR (sans !)
                        val = rest[1:].strip()
                        val = re.sub(r'\s*;.*$', '', val).strip()
                        return f'{label_candidate} = {self.convert_expression(val)}'
                    # C'est un label : ajouter ':'
                    converted_rest = self.convert_expression(rest)
                    if rest:
                        return f'{label_candidate}:\n{indent}        {converted_rest}'
                    else:
                        return f'{label_candidate}:'

        # Ligne d'instruction normale : convertir les operateurs
        converted = self.convert_expression(line)
        # Normaliser les caracteres non-ASCII (ex: accents dans les commentaires)
        return to_ascii_comment(converted)

    def convert(self):
        """Convertit le fichier source. Retourne (lignes_converties, warnings)."""
        try:
            with open(self.source_path, 'rb') as f:
                raw = f.read()
            # Supprimer les octets nuls (causent des erreurs dans le lexer)
            raw = bytes(b for b in raw if b != 0)
            raw = raw.replace(b'\r', b'')
            try:
                source = raw.decode('utf-8')
            except UnicodeDecodeError:
                source = raw.decode('latin-1')
            # Supprimer le caractere de remplacement Unicode
            source = source.replace('�', '?')
        except Exception as e:
            print(f'Erreur lecture : {e}', file=sys.stderr)
            sys.exit(1)

        lines = source.splitlines()
        result = []

        result.append('; -*- coding: utf-8 -*-')
        result.append(f'; Converti depuis {os.path.basename(self.source_path)}'
                      f' par acme2clasm')
        result.append('; Verifier les lignes marquees "TODO" avant assemblage')
        result.append('')

        for i, line in enumerate(lines, 1):
            converted = self.convert_line(i, line)
            result.append(converted)

        return result

    def format_report(self):
        """Formate le rapport des avertissements."""
        if not self.warnings:
            return 'Conversion terminee sans avertissement.'
        lines = [f'{len(self.warnings)} avertissement(s) :']
        for lineno, msg in self.warnings:
            lines.append(f'  Ligne {lineno:4d} : {msg}')
        return '\n'.join(lines)


# --------------------------------------------------------------------------
#  Point d'entree
# --------------------------------------------------------------------------

def main():
    parser = argparse.ArgumentParser(
        description='Convertit un fichier ACME vers la syntaxe cl-asm.')
    parser.add_argument('input',  help='fichier source ACME (.s)')
    parser.add_argument('-o', '--output', help='fichier de sortie (.asm)')
    parser.add_argument('--report', action='store_true',
                        help='affiche le rapport de conversion')
    args = parser.parse_args()

    if not os.path.isfile(args.input):
        print(f'Erreur : fichier introuvable : {args.input}', file=sys.stderr)
        sys.exit(1)

    # Fichier de sortie par defaut
    output_path = args.output
    if not output_path:
        base = os.path.splitext(args.input)[0]
        output_path = base + '.asm'

    converter = AcmeConverter(args.input)
    converted_lines = converter.convert()

    with open(output_path, 'w', encoding='utf-8') as f:
        f.write('\n'.join(converted_lines))
        if not converted_lines[-1].endswith('\n'):
            f.write('\n')

    print(f'{os.path.basename(args.input)} -> {output_path}')

    if args.report or converter.warnings:
        print(converter.format_report())


if __name__ == '__main__':
    main()
