#!/bin/sh
# acme2clasm -- Convertit un fichier ACME vers la syntaxe cl-asm.
# Détecte automatiquement SBCL ou CLISP.
#
# Usage :
#   ./acme2clasm source.s
#   ./acme2clasm source.s -o sortie.asm
#   ./acme2clasm source.s --report

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
LISP_SCRIPT="$SCRIPT_DIR/acme2clasm.lisp"

if [ ! -f "$LISP_SCRIPT" ]; then
    echo "Erreur : acme2clasm.lisp introuvable dans $SCRIPT_DIR" >&2
    exit 1
fi

if command -v sbcl >/dev/null 2>&1; then
    exec sbcl --noinform --script "$LISP_SCRIPT" -- "$@"
elif command -v clisp >/dev/null 2>&1; then
    exec clisp -q "$LISP_SCRIPT" -- "$@"
elif command -v ecl >/dev/null 2>&1; then
    exec ecl --load "$LISP_SCRIPT" -- "$@"
else
    echo "Erreur : SBCL, CLISP ou ECL requis pour utiliser acme2clasm." >&2
    exit 1
fi
